{
  "name": "zipsignal-ingest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "집시그널 실거래 수집 배치 — 국토부 공개 API를 긁어 Cloudflare D1(zipsignal-db)에 적재",
  "scripts": {
